# --- Model provider --------------------------------------------------------
# "anthropic" (default) or "openai".
# GLM-5.2 via BigModel uses the Anthropic protocol, so the defaults below work
# out of the box with a BigModel API key. For OpenAI/OpenRouter/Ollama set
# MODEL_PROVIDER=openai and fill the OPENAI_* vars.
MODEL_PROVIDER=anthropic
MODEL=GLM-5.2

# Anthropic-protocol credentials (BigModel GLM, Anthropic, Z.ai, …)
ANTHROPIC_API_KEY=your-bigmodel-key-here
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic

# OpenAI-protocol credentials (only used when MODEL_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Directory the agent operates on (real local files) --------------------
# Leave blank / unset to default to the server's current working directory.
WORKDIR=

# --- Conversation history persistence --------------------------------------
# SQLite (default, zero-dependency):
DATABASE_URL=sqlite:///./data/checkpoints.db
# Postgres (optional): postgresql+psycopg://user:pass@host:5432/deepopen

# --- Server ----------------------------------------------------------------
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=*
